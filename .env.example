# Environment Variables — Savara Firebase Config
#
# 1. Go to https://console.firebase.google.com
# 2. Create a new project called "savara"
# 3. Add a Web App inside the project
# 4. Copy your Firebase config values below
# 5. Enable "Email/Password" under Authentication > Sign-in method
# 6. Create a Firestore database (start in test mode)

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
